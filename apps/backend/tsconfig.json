{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"declaration": true,
		"outDir": "./dist",
		"rootDir": "../..",
		"types": ["node", "bun-types"],
		"verbatimModuleSyntax": false,
		"jsx": "react-jsx"
	},
	"include": ["src/**/*", "../../ee/backend/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
